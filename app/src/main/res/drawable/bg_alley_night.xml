<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base dark background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#FF0A0A1A"
                android:centerColor="#FF0D1B2A"
                android:endColor="#FF1A1A2E" />
        </shape>
    </item>
    <!-- Ground area -->
    <item android:top="350dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF1A1A2E" />
        </shape>
    </item>
</layer-list>
